--- a/lib/libmenu.c
+++ b/lib/libmenu.c
@@
-        if (ch != TIMER)
-            not_delay = 1;
+        if (ch == TIMER) {
+            if (timeout > 0 && --timeout == 0)
+                return MENU_BOOT_DEFAULT;
+        } else if (ch == '\r' || ch == '\n') {
+            return MENU_BOOT_CURRENT;
+        } else if (ch == 'c') {
+            return MENU_MAINTENANCE;
+        } else if (is_navigation_key(ch)) {
+            select_menu_item(ch);
+            timeout = configured_timeout ? configured_timeout : SAFE_DEFAULT_TIMEOUT;
+        } else {
+            /* Ignore UART noise and unrecognised bytes; do not freeze countdown. */
+        }
